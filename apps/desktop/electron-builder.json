{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.potato-cannon.app",
  "productName": "Potato Cannon",
  "directories": {
    "output": "release"
  },
  "files": [
    "out/**/*"
  ],
  "extraResources": [
    {
      "from": "../daemon/dist",
      "to": "daemon/dist"
    },
    {
      "from": "../daemon/bin",
      "to": "daemon/bin"
    },
    {
      "from": "../daemon/package.json",
      "to": "daemon/package.json"
    },
    {
      "from": "../frontend/dist",
      "to": "frontend"
    },
    {
      "from": "build/icon.png",
      "to": "icon.png"
    }
  ],
  "afterPack": "./scripts/copy-native-modules.cjs",
  "mac": {
    "target": ["dmg", "zip"],
    "icon": "build/icon.icns"
  },
  "win": {
    "target": ["nsis", "zip"],
    "icon": "build/icon.ico"
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "icon": "build/icon.png"
  }
}
