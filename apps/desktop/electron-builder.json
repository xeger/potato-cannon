{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.potato-cannon.app",
  "productName": "Potato Cannon",
  "directories": {
    "output": "release"
  },
  "files": [
    "out/**/*"
  ],
  "asarUnpack": [
    "node_modules/better-sqlite3/**/*",
    "node_modules/node-pty/**/*"
  ],
  "extraResources": [
    {
      "from": "build/daemon",
      "to": "daemon",
      "filter": ["**/*"]
    },
    {
      "from": "../frontend/dist",
      "to": "frontend"
    },
    {
      "from": "build/icon.png",
      "to": "icon.png"
    }
  ],
  "afterPack": "./scripts/copy-native-modules.cjs",
  "mac": {
    "target": ["dmg", "zip"],
    "icon": "build/icon.icns"
  },
  "win": {
    "target": ["nsis", "zip"],
    "icon": "build/icon.ico"
  },
  "linux": {
    "target": ["AppImage"],
    "icon": "build/icon.png"
  }
}
