{
  "name": "@potato-cannon/daemon",
  "version": "4.0.0",
  "description": "Multi-agent software engineering daemon",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "potato-cannon": "./bin/potato-cannon.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/system-agents/agents dist/system-agents/",
    "start": "node dist/index.js",
    "dev": "tsc -w & NODE_ENV=development node --watch dist/index.js",
    "test": "node --experimental-test-module-mocks --test dist/**/*.test.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.73.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@potato-cannon/shared": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "commander": "^12.0.0",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "node-pty": "^1.1.0",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.25",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.30",
    "@types/proper-lockfile": "^4.1.4",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": ["darwin", "linux"]
}
